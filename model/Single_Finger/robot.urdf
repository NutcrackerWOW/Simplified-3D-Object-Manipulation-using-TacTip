<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="Robot">
  


  <material name="silver">
    
  
    <color rgba="0.700 0.700 0.700 1.000"/>
    

  </material>
  

  

  <xacro:property name="body_color" value="Gazebo/Silver"/>
  <gazebo>
    
  
    <plugin name="control" filename="libgazebo_ros_control.so"/>
    

  </gazebo>
  <gazebo reference="base_link">
    
  
    <material>${body_color}</material>
    
  
    <mu1>0.2</mu1>
    
  
    <mu2>0.2</mu2>
    
  
    <selfCollide>true</selfCollide>
    
  
    <gravity>true</gravity>
    

  </gazebo>
  <gazebo reference="End_1">
    
  
    <material>${body_color}</material>
    
  
    <mu1>0.2</mu1>
    
  
    <mu2>0.2</mu2>
    
  
    <selfCollide>true</selfCollide>
    

  </gazebo>
  <gazebo reference="Middle_1">
    
  
    <material>${body_color}</material>
    
  
    <mu1>0.2</mu1>
    
  
    <mu2>0.2</mu2>
    
  
    <selfCollide>true</selfCollide>
    

  </gazebo>
  <gazebo reference="Tip_1">
    
  
    <material>${body_color}</material>
    
  
    <mu1>0.2</mu1>
    
  
    <mu2>0.2</mu2>
    
  
    <selfCollide>true</selfCollide>
    

  </gazebo>
  <gazebo reference="Horizontal_1">
    
  
    <material>${body_color}</material>
    
  
    <mu1>0.2</mu1>
    
  
    <mu2>0.2</mu2>
    
  
    <selfCollide>true</selfCollide>
    

  </gazebo>
  

  <link name="base_link">
    
  
    <inertial>
      
    
      <origin xyz="-0.01046674943697785 0.005000000074505806 0.005000000104308129" rpy="0 0 0"/>
      
    
      <mass value="0.0028030752101132865"/>
      
    
      <inertia ixx="0.0" iyy="0.0" izz="0.0" ixy="0.0" iyz="0.0" ixz="-0.0"/>
      
  
    </inertial>
    
  
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.obj" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.obj" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    

  </link>
  


  <link name="End_1">
    
  
    <inertial>
      
    
      <origin xyz="0.025895244716314186 0.0020000001506455846 0.0" rpy="0 0 0"/>
      
    
      <mass value="0.03840768857506156"/>
      
    
      <inertia ixx="1e-06" iyy="9e-06" izz="9e-06" ixy="-0.0" iyz="0.0" ixz="-0.0"/>
      
  
    </inertial>
    
  
    <visual>
      
    
      <origin xyz="-0.0 -0.003 -0.005" rpy="0 0 0"/>
      
    
      <geometry>
        
      
        <mesh filename="meshes/End_1.obj" scale="0.001 0.001 0.001"/>
        
    
      </geometry>
      
    
      <material name="silver"/>
      
  
    </visual>
    
  
    <collision>
      
    
      <origin xyz="-0.0 -0.003 -0.005" rpy="0 0 0"/>
      
    
      <geometry>
        
      
        <mesh filename="meshes/End_1.obj" scale="0.001 0.001 0.001"/>
        
    
      </geometry>
      
  
    </collision>
    

  </link>
  


  <link name="Middle_1">
    
  
    <inertial>
      
    
      <origin xyz="0.0158970046592357 0.002000000074505808 0.0" rpy="0 0 0"/>
      
    
      <mass value="0.02270768818904698"/>
      
    
      <inertia ixx="0.0" iyy="2e-06" izz="2e-06" ixy="0.0" iyz="0.0" ixz="0.0"/>
      
  
    </inertial>
    
  
    <visual>
      
    
      <origin xyz="-0.05 -0.003 -0.005" rpy="0 0 0"/>
      
    
      <geometry>
        
      
        <mesh filename="meshes/Middle_1.obj" scale="0.001 0.001 0.001"/>
        
    
      </geometry>
      
    
      <material name="silver"/>
      
  
    </visual>
    
  
    <collision>
      
    
      <origin xyz="-0.05 -0.003 -0.005" rpy="0 0 0"/>
      
    
      <geometry>
        
      
        <mesh filename="meshes/Middle_1.obj" scale="0.001 0.001 0.001"/>
        
    
      </geometry>
      
  
    </collision>
    

  </link>
  


  <link name="Tip_1">
    
  
    <inertial>
      
    
      <origin xyz="0.009314105642884929 0.0020000000909095074 -0.0004308862060881666" rpy="0 0 0"/>
      
    
      <mass value="0.01235387253010107"/>
      
    
      <inertia ixx="0.0" iyy="1e-06" izz="1e-06" ixy="0.0" iyz="-0.0" ixz="0.0"/>
      
  
    </inertial>
    
  
    <visual>
      
    
      <origin xyz="-0.08 -0.003 -0.005" rpy="0 0 0"/>
      
    
      <geometry>
        
      
        <mesh filename="meshes/Tip_1.obj" scale="0.001 0.001 0.001"/>
        
    
      </geometry>
      
    
      <material name="silver"/>
      
  
    </visual>
    
  
    <collision>
      
    
      <origin xyz="-0.08 -0.003 -0.005" rpy="0 0 0"/>
      
    
      <geometry>
        
      
        <mesh filename="meshes/Tip_1.obj" scale="0.001 0.001 0.001"/>
        
    
      </geometry>
      
  
    </collision>
    

  </link>
  


  <link name="Horizontal_1">
    
  
    <inertial>
      
    
      <origin xyz="0.004496395775024517 1.4901161294461618e-10 -0.0020000000367405204" rpy="0 0 0"/>
      
    
      <mass value="0.008914612994797655"/>
      
    
      <inertia ixx="0.0" iyy="0.0" izz="0.0" ixy="0.0" iyz="0.0" ixz="-0.0"/>
      
  
    </inertial>
    
  
    <visual>
      
    
      <origin xyz="0.01 -0.005 -0.007" rpy="0 0 0"/>
      
    
      <geometry>
        
      
        <mesh filename="meshes/Horizontal_1.obj" scale="0.001 0.001 0.001"/>
        
    
      </geometry>
      
    
      <material name="silver"/>
      
  
    </visual>
    
  
    <collision>
      
    
      <origin xyz="0.01 -0.005 -0.007" rpy="0 0 0"/>
      
    
      <geometry>
        
      
        <mesh filename="meshes/Horizontal_1.obj" scale="0.001 0.001 0.001"/>
        
    
      </geometry>
      
  
    </collision>
    

  </link>
  


  <joint name="rotation_2" type="revolute">
    <origin xyz="0.01 -0.002 -0.002" rpy="0 0 0"/>
    <parent link="Horizontal_1"/>
    <child link="End_1"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.5708" upper="1.5708" effort="100" velocity="100"/>
  </joint>

  <joint name="rotation_3" type="revolute">
    <origin xyz="0.05 0.0 0.0" rpy="0 0 0"/>
    <parent link="End_1"/>
    <child link="Middle_1"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.5708" upper="1.5708" effort="100" velocity="100"/>
  </joint>

  <joint name="rotation_5" type="revolute">
    <origin xyz="0.03 0.0 0.0" rpy="0 0 0"/>
    <parent link="Middle_1"/>
    <child link="Tip_1"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-1.5708" upper="1.5708" effort="100" velocity="100"/>
  </joint>

  <joint name="rotation_6" type="revolute">
    <origin xyz="-0.01 0.005 0.007" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="Horizontal_1"/>
    <axis xyz="0.0 0.0 1.0"/>
    <limit lower="-1.5708" upper="1.5708" effort="100" velocity="100"/>
  </joint>

  


</robot>
